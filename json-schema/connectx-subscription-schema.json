{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amdocs/refs/heads/main/json-schema/connectx-subscription-schema.json",
  "title": "Subscription",
  "description": "Subscription schema from Amdocs API",
  "type": "object",
  "properties": {
    "subscriptionId": {
      "type": "string"
    },
    "customerId": {
      "type": "string"
    },
    "productId": {
      "type": "string"
    },
    "productName": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Suspended",
        "Cancelled",
        "Pending"
      ]
    },
    "startDate": {
      "type": "string",
      "format": "date"
    },
    "endDate": {
      "type": "string",
      "format": "date"
    },
    "monthlyCharge": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "addons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "addonId": {
            "type": "string"
          },
          "addonName": {
            "type": "string"
          },
          "charge": {
            "type": "number"
          }
        }
      }
    }
  }
}